generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?
  emailVerified Boolean?
}

model Shop {
  id                String              @id @default(cuid())
  shopDomain        String              @unique
  name              String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  users             User[]
  collectionSeasons CollectionSeason[]
  suppliers         Supplier[]
  products          DevelopmentProduct[]
  activityLogs      ActivityLog[]
}

model User {
  id                 String               @id @default(cuid())
  shopId             String
  email              String
  name               String?
  role               String               @default("EDITOR")
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  shop               Shop                 @relation(fields: [shopId], references: [id], onDelete: Cascade)
  ownedProducts      DevelopmentProduct[] @relation("ProductOwner")
  fitComments        FitComment[]
  decisions          ProductDecision[]
  approvals          Approval[]
  activityLogs       ActivityLog[]

  @@unique([shopId, email])
  @@index([shopId, role])
}

model CollectionSeason {
  id          String               @id @default(cuid())
  shopId      String
  name        String
  code        String?
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  shop        Shop                 @relation(fields: [shopId], references: [id], onDelete: Cascade)
  products    DevelopmentProduct[]

  @@unique([shopId, name])
  @@index([shopId])
}

model Supplier {
  id           String               @id @default(cuid())
  shopId       String
  name         String
  contactName  String?
  contactEmail String?
  privateNotes String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  shop         Shop                 @relation(fields: [shopId], references: [id], onDelete: Cascade)
  products     DevelopmentProduct[]
  samples      ProductSample[]

  @@unique([shopId, name])
  @@index([shopId])
}

model DevelopmentProduct {
  id                 String                   @id @default(cuid())
  shopId             String
  collectionSeasonId String?
  supplierId         String?
  ownerId            String?
  title              String?
  workingName        String
  category           String?
  description        String?
  status             String                   @default("IDEA")
  readinessScore     Int                      @default(0)
  readinessIssues    String?
  lastReadinessAt    DateTime?
  targetLaunchAt     DateTime?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  shop               Shop                     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  collectionSeason   CollectionSeason?        @relation(fields: [collectionSeasonId], references: [id], onDelete: SetNull)
  supplier           Supplier?                @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  owner              User?                    @relation("ProductOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  variants           DevelopmentVariant[]
  costing            ProductCosting?
  samples            ProductSample[]
  fitComments        FitComment[]
  decisions          ProductDecision[]
  approvals          Approval[]
  activityLogs       ActivityLog[]

  @@index([shopId, status])
  @@index([shopId, collectionSeasonId])
  @@index([shopId, supplierId])
}

model DevelopmentVariant {
  id          String             @id @default(cuid())
  productId   String
  color       String
  size        String
  sku         String?
  position    Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  product     DevelopmentProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, color, size])
  @@index([productId])
}

model ProductCosting {
  id                String             @id @default(cuid())
  productId         String             @unique
  currencyCode      String             @default("USD")
  purchaseCostCents Int?
  landedCostCents   Int?
  retailPriceCents  Int?
  targetMarginBps   Int?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  product           DevelopmentProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductSample {
  id          String             @id @default(cuid())
  productId   String
  supplierId  String?
  round       Int
  status      String             @default("REQUESTED")
  requestedAt DateTime?
  receivedAt  DateTime?
  notes       String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  product     DevelopmentProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier    Supplier?          @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  fitComments FitComment[]

  @@unique([productId, round])
  @@index([productId])
}

model FitComment {
  id        String             @id @default(cuid())
  productId String
  sampleId  String?
  authorId  String?
  body      String
  createdAt DateTime           @default(now())
  product   DevelopmentProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  sample    ProductSample?     @relation(fields: [sampleId], references: [id], onDelete: SetNull)
  author    User?              @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([productId])
}

model ProductDecision {
  id        String             @id @default(cuid())
  productId String
  authorId  String?
  type      String
  notes     String?
  createdAt DateTime           @default(now())
  product   DevelopmentProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  author    User?              @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([productId])
}

model Approval {
  id        String             @id @default(cuid())
  productId String
  reviewerId String?
  type      String
  status    String             @default("PENDING")
  comments  String?
  decidedAt DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  product   DevelopmentProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  reviewer  User?              @relation(fields: [reviewerId], references: [id], onDelete: SetNull)

  @@unique([productId, type])
  @@index([productId, status])
}

model ActivityLog {
  id        String              @id @default(cuid())
  shopId    String
  productId String?
  actorId   String?
  action    String
  details   String?
  createdAt DateTime            @default(now())
  shop      Shop                @relation(fields: [shopId], references: [id], onDelete: Cascade)
  product   DevelopmentProduct? @relation(fields: [productId], references: [id], onDelete: SetNull)
  actor     User?               @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([shopId, createdAt])
  @@index([productId])
}
